import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt

# Numele coloanelor
cols = ['age', 'sex', 'cp', 'trestbps', 'chol', 'fbs', 'restecg', 
        'thalach', 'exang', 'oldpeak', 'slope', 'ca', 'thal', 'target']

#  Încărcare date 
df = pd.read_csv('processed.cleveland.data', names=cols, na_values='?')


# target in binar 0 = sănătos, 1 = bolnav
df['target'] = df['target'].apply(lambda x: 1 if x > 0 else 0)
# Ștergem randuri cu valori lipsă
df.dropna(inplace=True)

# Analiză (EDA)
print("Informații set de date:")
print(df.info())

# Vizualizare corelație
plt.figure(figsize=(10, 8))
sns.heatmap(df.corr(), annot=True, cmap='coolwarm', fmt='.2f')
plt.title('Matricea de Corelație ')
plt.show()
